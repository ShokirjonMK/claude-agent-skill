# ─────────────────────────────────────────────────────────────────────────────
# Orchestra — BOOTSTRAP konfiguratsiya (.env)
# Bu yerda FAQAT tizimni ko'tarish uchun zarur narsalar bo'ladi.
# API kalitlar, tokenlar, modellar va SSH ma'lumotlari admin-panel orqali
# (DB'da Fernet bilan shifrlangan holda) dinamik kiritiladi — bu yerga shart emas.
# ─────────────────────────────────────────────────────────────────────────────

# Ma'lumotlar bazasi. Postgres (production) yoki SQLite (local/test).
#   Postgres:  postgresql://orchestra:orchestra@postgres:5432/orchestra
#   SQLite:    sqlite:///orchestra.db
DB_DSN=postgresql://orchestra:orchestra@postgres:5432/orchestra

# Fernet master kalit — barcha secrets shu bilan shifrlanadi.
# YANGI kalit yaratish:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# DIQQAT: bu kalitni HECH QACHON DB'ga yoki kodga yozmang. Yo'qotsangiz — barcha secrets yo'qoladi.
SECRET_ENC_KEY=

# Web admin-panel JWT/session imzo kaliti.
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
WEB_JWT_SECRET=

# Birinchi admin foydalanuvchi (initdb / createadmin uchun).
BOOTSTRAP_ADMIN_USER=admin
BOOTSTRAP_ADMIN_PASS=

# ── Quyidagilar default; odatda admin-paneldagi Secrets sahifasidan boshqariladi ──
POLL_INTERVAL=2
MAX_RETRY=2
MAX_PARALLEL=5
PLANNER_MODEL=claude-opus-4-8
EXECUTOR_MODEL=claude-sonnet-4-6
REVIEWER_MODEL=claude-sonnet-4-6
CHAT_MODEL=claude-sonnet-4-6

# Ixtiyoriy bootstrap (yaxshisi UI'dan kiriting):
# ANTHROPIC_API_KEY=
# TG_BOT_TOKEN=
# TG_CHAT_ID=

# Web server
WEB_HOST=0.0.0.0
WEB_PORT=8000
